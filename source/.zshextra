export PROJECT_PATH="~/Projects"
export PNPM_HOME="$HOME/.local/share/pnpm/"
export PROJECT_PATH="~/Projects"

alias to_portfolio="cd ${PROJECT_PATH}/portfolio" 
alias to_ehoi="cd ${PROJECT_PATH}/ehoi-package-id-grabber" 
